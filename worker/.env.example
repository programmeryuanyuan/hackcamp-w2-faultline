# ── LLM（默认 DeepSeek；换别家改这三个值即可）────────────────────────────
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── Polymarket ────────────────────────────────────────────────────────────────
POLYMARKET_API_HOST=https://clob.polymarket.com

# ── 链上（D2 部署合约后填）────────────────────────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org
WALLET_PRIVATE_KEY=0xxxx
SNAPSHOT_REGISTRY_ADDRESS=

# ── Telegram（D4 才用，今天空着）──────────────────────────────────────────
TG_BOT_TOKEN=
TG_CHAT_ID=

# ── 代理（Polymarket 国内需要，端口换成你的实际端口）────────────────────
HTTPS_PROXY=http://127.0.0.1:7897

# ── Runtime ───────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=60000
MIN_EDGE=0.04
